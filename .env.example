TZ=America/Los_Angeles

# Shared paths
LLM_WIKI_ROOT=/srv/llm-wiki

# Open WebUI
OPENWEBUI_PORT=3000
OPENWEBUI_SECRET_KEY=change-me

# SilverBullet
SILVERBULLET_PORT=3001

# Intake service
INTAKE_PORT=8787
INTAKE_SHARED_TOKEN=change-me-long-random-string
INTAKE_STORAGE_PATH=/data
INTAKE_BASE_URL=https://wiki.example.com

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-me-telegram-secret
TELEGRAM_ALLOWED_CHAT_IDS=

# Optional Twilio WhatsApp
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+10000000000

# Git automation
GIT_AUTOCOMMIT_NAME=llm-wiki-bot
GIT_AUTOCOMMIT_EMAIL=bot@example.com

# Worker runtime
QUERY_POLL_SECONDS=5
MAINTAINER_INTERVAL_SECONDS=300
AUTO_INGEST_ENABLED=true
AUTO_LINT_ENABLED=true
LINT_INTERVAL_SECONDS=900
LINT_BATCH_SIZE=12
LINT_BATCHES_PER_INTERVAL=3
AUTO_COMMIT_ENABLED=false

# External OpenClaw hooks
# The worker will set:
#   LLM_WIKI_ROOT
#   LLM_WIKI_JOB_FILE
#   LLM_WIKI_OUTPUT_FILE
# before executing these shell commands.
OPENCLAW_QUERY_COMMAND=python /workspace/llm-wiki/ops/openclaw/run_query_job.py
OPENCLAW_INGEST_COMMAND=python /workspace/llm-wiki/ops/openclaw/run_ingest_job.py
OPENCLAW_LINT_COMMAND=python /workspace/llm-wiki/ops/openclaw/run_lint_job.py

# OpenClaw agent ids used by the adapters
OPENCLAW_QUERY_AGENT_ID=telegram-query
OPENCLAW_INGEST_AGENT_ID=wiki-maintainer
OPENCLAW_LINT_AGENT_ID=wiki-linter
OPENCLAW_AGENT_TIMEOUT_SECONDS=180

# These are the actual commands that your OpenClaw environment should run.
# They receive a prompt in LLM_WIKI_OPENCLAW_PROMPT and may either:
# - print result JSON to stdout, or
# - write result JSON directly to LLM_WIKI_OUTPUT_FILE
# If left blank, the adapters will default to:
#   openclaw agent --local --json --agent "$LLM_WIKI_OPENCLAW_AGENT_ID" --message "$LLM_WIKI_OPENCLAW_PROMPT"
OPENCLAW_QUERY_EXEC_COMMAND=
OPENCLAW_INGEST_EXEC_COMMAND=
OPENCLAW_LINT_EXEC_COMMAND=
